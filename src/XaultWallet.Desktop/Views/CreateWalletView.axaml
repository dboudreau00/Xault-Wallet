<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:XaultWallet.Desktop.ViewModels"
             xmlns:conv="clr-namespace:XaultWallet.Desktop"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="700"
             x:Class="XaultWallet.Desktop.Views.CreateWalletView"
             x:DataType="vm:CreateWalletViewModel">

    <!-- Root grid so the verification overlay can sit above the form -->
    <Grid>
        <ScrollViewer>
            <Border MaxWidth="860" Margin="24,20" VerticalAlignment="Top" HorizontalAlignment="Center"
                    Classes="card" Padding="28,24">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Create your vault" Classes="h1"/>
                        <TextBlock Classes="muted"
                                   Text="Encrypted at rest with AES-256-GCM · key derived with Argon2id."/>
                    </StackPanel>

                    <Border IsVisible="{Binding IsMainnet}" Background="#2A1414" BorderBrush="#7A2E2E"
                            BorderThickness="1" CornerRadius="10" Padding="14">
                        <StackPanel Spacing="5">
                            <TextBlock Text="⚠ Mainnet — real funds at risk" FontWeight="Bold" Foreground="#FF6B6B"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#E8B0B0"
                                       Text="Unaudited beta software. Mainnet transactions are irreversible. Test on stagenet/testnet first and keep an independent seed backup. 'Wipe on duress' permanently destroys the real seed on this device."/>
                        </StackPanel>
                    </Border>

                    <!-- Two columns: setup on the left, security on the right -->
                    <Grid ColumnDefinitions="*,28,*">
                        <StackPanel Grid.Column="0" Spacing="13">
                            <TextBlock Text="NETWORK &amp; NODE" Classes="eyebrow"/>
                            <Grid ColumnDefinitions="Auto,10,*">
                                <ComboBox Grid.Column="0" SelectedIndex="{Binding NetworkIndex}" Width="128">
                                    <ComboBoxItem>Mainnet</ComboBoxItem>
                                    <ComboBoxItem>Stagenet</ComboBoxItem>
                                    <ComboBoxItem>Testnet</ComboBoxItem>
                                </ComboBox>
                                <TextBox Grid.Column="2" Text="{Binding DaemonAddress}" Watermark="Daemon address"/>
                            </Grid>

                            <TextBlock Text="REAL WALLET" Classes="eyebrow" Margin="0,4,0,0"/>
                            <StackPanel Orientation="Horizontal" Spacing="18">
                                <RadioButton GroupName="RealMode" Content="Create new" IsChecked="{Binding CreateNewReal, Mode=TwoWay}"/>
                                <RadioButton GroupName="RealMode" Content="Import seed"/>
                            </StackPanel>

                            <Button Content="Generate new seed" Command="{Binding GenerateRealSeedCommand}"
                                    IsEnabled="{Binding !Busy}" HorizontalAlignment="Left"
                                    IsVisible="{Binding CreateNewReal}"/>

                            <StackPanel Spacing="10" IsVisible="{Binding !CreateNewReal}">
                                <TextBox Classes="mono" Watermark="Existing 25-word seed" Text="{Binding RealMnemonic}"
                                         AcceptsReturn="True" Height="64" TextWrapping="Wrap"/>
                                <TextBlock Text="SYNC FROM" Classes="eyebrow"/>
                                <ComboBox SelectedIndex="{Binding RestoreMode}" HorizontalAlignment="Stretch">
                                    <ComboBoxItem>Full history — scan everything (safest, slowest)</ComboBoxItem>
                                    <ComboBoxItem>From a specific block height</ComboBoxItem>
                                    <ComboBoxItem>From now — newest blocks only (new seeds only)</ComboBoxItem>
                                </ComboBox>
                                <TextBox Classes="mono" Watermark="Block height (your wallet's creation height)"
                                         Text="{Binding RestoreHeight}" IsVisible="{Binding IsSpecificHeight}"
                                         HorizontalAlignment="Left" Width="280"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextTertiary}"
                                           Text="'From now' skips all past blocks — only use it for a brand-new seed with no history, or you may not see existing funds. If unsure, pick Full history."/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="13">
                            <TextBlock Text="MAIN PASSWORD" Classes="eyebrow"/>
                            <TextBox Watermark="Main password" PasswordChar="&#9679;" Text="{Binding MainPassword}"/>
                            <TextBlock Text="{Binding StrengthLabel}" Classes="muted" Margin="0,-4,0,0"/>
                            <TextBox Watermark="Confirm password" PasswordChar="&#9679;" Text="{Binding MainPasswordConfirm}"/>

                            <CheckBox Content="Set up a duress (decoy) password" IsChecked="{Binding EnableDuress}" Margin="0,4,0,0"/>
                            <StackPanel Spacing="10" IsVisible="{Binding EnableDuress}">
                                <TextBlock TextWrapping="Wrap" Classes="muted"
                                           Text="The duress password opens a separate decoy wallet that looks identical."/>
                                <TextBox Watermark="Duress password" PasswordChar="&#9679;" Text="{Binding DuressPassword}"/>
                                <StackPanel Orientation="Horizontal" Spacing="18">
                                    <RadioButton GroupName="DuressMode" Content="Generate decoy" IsChecked="{Binding CreateNewDuress, Mode=TwoWay}"/>
                                    <RadioButton GroupName="DuressMode" Content="Import decoy"/>
                                </StackPanel>
                                <StackPanel Spacing="8" IsVisible="{Binding CreateNewDuress}">
                                    <Button Content="Generate decoy seed" Command="{Binding GenerateDuressSeedCommand}"
                                            IsEnabled="{Binding !Busy}" HorizontalAlignment="Left"/>
                                    <TextBox Classes="mono" Text="{Binding DuressMnemonic}" IsReadOnly="True" TextWrapping="Wrap"
                                             MinHeight="52" IsVisible="{Binding DuressSeedGenerated}" FontSize="12.5"/>
                                    <Button Content="Download decoy backup" Command="{Binding DownloadDuressBackupCommand}"
                                            IsVisible="{Binding DuressSeedGenerated}" HorizontalAlignment="Left"/>
                                </StackPanel>
                                <StackPanel Spacing="8" IsVisible="{Binding !CreateNewDuress}">
                                    <TextBox Classes="mono" Watermark="Decoy 25-word seed" Text="{Binding DuressMnemonic}"
                                             AcceptsReturn="True" Height="52" TextWrapping="Wrap"/>
                                </StackPanel>
                                <CheckBox Content="Wipe the real wallet on duress" IsChecked="{Binding WipeRealOnDuress}"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#E0A030"
                                           Text="Irreversible on this device. Only enable if your real seed is backed up elsewhere."/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Generated seed: full-width numbered grid -->
                    <StackPanel Spacing="10" IsVisible="{Binding RealSeedGenerated}">
                        <Separator/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="YOUR RECOVERY SEED · 25 WORDS" Classes="eyebrow" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" IsVisible="{Binding RealVerified}" Background="#173A2B"
                                    BorderBrush="#2E6E52" BorderThickness="1" CornerRadius="6" Padding="8,3">
                                <TextBlock Text="✓ Backup verified" FontSize="11" FontWeight="SemiBold" Foreground="#5FD0A0"/>
                            </Border>
                        </Grid>
                        <TextBlock Classes="mono" FontSize="12" Foreground="#E0A030" TextWrapping="Wrap"
                                   Text="Write these down in order and keep them offline. They are the only way to recover your funds."/>

                        <Border Background="{StaticResource InsetBg}" BorderBrush="{StaticResource BorderSubtle}"
                                BorderThickness="1" CornerRadius="10" Padding="14">
                            <ItemsControl ItemsSource="{Binding RealSeedWords}" x:CompileBindings="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="5"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,4">
                                            <TextBlock Text="{Binding Number}" FontFamily="Cascadia Code,Consolas,monospace"
                                                       FontSize="11" Foreground="{StaticResource TextTertiary}"
                                                       MinWidth="16" TextAlignment="Right" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Word}" FontFamily="Cascadia Code,Consolas,monospace"
                                                       FontSize="12.5" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Download backup (.txt)" Command="{Binding DownloadRealBackupCommand}"/>
                            <Button Content="Verify backup" Command="{Binding OpenVerifyCommand}"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="{Binding Error}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap"
                               IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <Button Content="Create vault" Classes="accent" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center" Command="{Binding CreateCommand}"
                            IsEnabled="{Binding !Busy}"/>
                    <ProgressBar IsIndeterminate="True" IsVisible="{Binding Busy}" Height="3"/>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- ===== Verification overlay ===== -->
        <Border IsVisible="{Binding ShowVerifyOverlay}" Background="#CC0D0D10">
            <Border Classes="card" Width="440" Padding="26" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Confirm your backup" Classes="h1"/>
                        <TextBlock Classes="muted" TextWrapping="Wrap"
                                   Text="Enter the words at these positions from your written backup."/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding VerifyPrompt1}" Classes="eyebrow"/>
                        <TextBox Text="{Binding VerifyInput1}"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding VerifyPrompt2}" Classes="eyebrow"/>
                        <TextBox Text="{Binding VerifyInput2}"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding VerifyPrompt3}" Classes="eyebrow"/>
                        <TextBox Text="{Binding VerifyInput3}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding VerifyMessage}" Foreground="{StaticResource DangerBrush}"
                               FontSize="12" TextWrapping="Wrap"
                               IsVisible="{Binding VerifyMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                        <Button Content="Cancel" Command="{Binding CloseVerifyCommand}"/>
                        <Button Content="Confirm" Classes="accent" Command="{Binding VerifyRealSeedCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
