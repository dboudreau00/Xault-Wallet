<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:XaultWallet.Desktop.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="620"
        x:Class="XaultWallet.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="XaultWallet" Width="900" Height="620"
        MinWidth="720" MinHeight="520"
        Background="#141416">

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Background="#0F0F11" Padding="16,10" BorderBrush="#242428" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <Border Width="22" Height="22" CornerRadius="11" Background="{StaticResource XmrOrangeBrush}"/>
                    <TextBlock Text="XaultWallet" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="Monero · encrypted at rest" FontSize="12" Opacity="0.5" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="2" Content="Settings" Command="{Binding OpenSettingsCommand}"
                        IsVisible="{Binding !SettingsOpen}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <ContentControl Grid.Row="1" Content="{Binding Current}" Margin="0"/>
    </Grid>
</Window>
