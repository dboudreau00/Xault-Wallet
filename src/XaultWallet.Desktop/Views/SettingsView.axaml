<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:XaultWallet.Desktop.ViewModels"
             xmlns:conv="clr-namespace:XaultWallet.Desktop"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="700"
             x:Class="XaultWallet.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer>
        <Border MaxWidth="720" Margin="24,20" VerticalAlignment="Top" HorizontalAlignment="Center"
                Classes="card" Padding="28,24">
            <StackPanel Spacing="14">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Settings" Classes="h1" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Close" Command="{Binding CloseCommand}"/>
                </Grid>

                <!-- monero-wallet-rpc binary -->
                <StackPanel Spacing="6">
                    <TextBlock Text="MONERO-WALLET-RPC EXECUTABLE" Classes="eyebrow"/>
                    <TextBlock TextWrapping="Wrap" Classes="muted"
                               Text="XaultWallet drives the official Monero wallet RPC binary; it doesn't reimplement Monero's cryptography. Point this at monero-wallet-rpc from a Monero CLI release."/>
                    <Grid ColumnDefinitions="*,8,Auto">
                        <TextBox Grid.Column="0" Classes="mono" FontSize="12.5"
                                 Watermark="Path to monero-wallet-rpc (blank = auto-detect)"
                                 Text="{Binding WalletRpcBinaryPath}"/>
                        <Button Grid.Column="2" Content="Browse&#8230;" Command="{Binding BrowseCommand}"/>
                    </Grid>
                    <TextBlock Text="{Binding DefaultBinaryHint}" Foreground="{StaticResource TextTertiary}"
                               FontSize="11" TextWrapping="Wrap"/>
                    <Button Content="Test binary" Command="{Binding TestBinaryCommand}" IsEnabled="{Binding !Busy}"
                            HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding BinaryTestResult}" TextWrapping="Wrap"
                               IsVisible="{Binding BinaryTestResult, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               Foreground="{Binding BinaryTestOk, Converter={x:Static conv:BoolToBrushConverter.OkWarn}}"/>
                </StackPanel>

                <Separator/>

                <!-- Daemon -->
                <StackPanel Spacing="6">
                    <TextBlock Text="DEFAULT NODE" Classes="eyebrow"/>
                    <TextBlock TextWrapping="Wrap" Classes="muted"
                               Text="Pre-fills the daemon address when you create a wallet. Existing wallets keep the node they were created with."/>

                    <ComboBox x:CompileBindings="False" HorizontalAlignment="Stretch"
                              ItemsSource="{Binding PresetNodes}" SelectedItem="{Binding SelectedPreset}"
                              PlaceholderText="Choose a reputable public node (optional)…">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextTertiary}" FontSize="11"
                               Text="Public nodes are third-party: the operator can see your IP and broadcast transactions, and nodes can go offline. Test before relying on one. For mainnet privacy, run your own node."/>

                    <Grid ColumnDefinitions="Auto,10,*">
                        <ComboBox Grid.Column="0" SelectedIndex="{Binding NetworkIndex}" Width="128">
                            <ComboBoxItem>Mainnet</ComboBoxItem>
                            <ComboBoxItem>Stagenet</ComboBoxItem>
                            <ComboBoxItem>Testnet</ComboBoxItem>
                        </ComboBox>
                        <TextBox Grid.Column="2" Classes="mono" FontSize="12.5"
                                 Watermark="http://host:port" Text="{Binding DefaultDaemonAddress}"/>
                    </Grid>
                    <Button Content="Test node" Command="{Binding TestDaemonCommand}" IsEnabled="{Binding !Busy}"
                            HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding DaemonTestResult}" TextWrapping="Wrap"
                               IsVisible="{Binding DaemonTestResult, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               Foreground="{Binding DaemonTestOk, Converter={x:Static conv:BoolToBrushConverter.OkWarn}}"/>
                </StackPanel>

                <Separator/>

                <!-- Refresh cadence + auto-lock -->
                <StackPanel Spacing="6">
                    <TextBlock Text="AUTO-REFRESH INTERVAL" Classes="eyebrow"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBox Text="{Binding AutoRefreshSeconds}" Width="100"/>
                        <TextBlock Text="seconds" Classes="muted" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="How often the open wallet re-checks balance and history (5&#8211;600s)."
                               Foreground="{StaticResource TextTertiary}" FontSize="11"/>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="AUTO-LOCK" Classes="eyebrow"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBox Text="{Binding AutoLockMinutes}" Width="100"/>
                        <TextBlock Text="minutes of inactivity (0 = never)" Classes="muted" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Locks the wallet automatically after no mouse or keyboard input. Shreds the open wallet; you'll re-enter your password."
                               Foreground="{StaticResource TextTertiary}" FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>

                <Separator/>

                <!-- Change this wallet's node (repoint an existing vault) -->
                <StackPanel Spacing="6" IsVisible="{Binding VaultExists}">
                    <TextBlock Text="CHANGE THIS WALLET'S NODE" Classes="eyebrow"/>
                    <TextBlock TextWrapping="Wrap" Classes="muted"
                               Text="Repoints your EXISTING wallet at a different node. (The Default Node above only affects wallets you create later.) Only the node URL changes — your seed and network stay the same. Pick a node on the same network. Takes effect the next time you unlock."/>

                    <ComboBox x:CompileBindings="False" HorizontalAlignment="Stretch"
                              ItemsSource="{Binding PresetNodes}" SelectedItem="{Binding SelectedRepointPreset}"
                              PlaceholderText="Pick a node (fills the address below)…">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBox Classes="mono" FontSize="12.5" Watermark="http://host:port"
                             Text="{Binding RepointNodeAddress}"/>
                    <Button Content="Test node" Command="{Binding TestRepointNodeCommand}" IsEnabled="{Binding !Busy}"
                            HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding RepointTestResult}" TextWrapping="Wrap"
                               IsVisible="{Binding RepointTestResult, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               Foreground="{Binding RepointTestOk, Converter={x:Static conv:BoolToBrushConverter.OkWarn}}"/>

                    <TextBox Watermark="Wallet password (confirms the change)" PasswordChar="&#9679;"
                             Text="{Binding RepointPassword}"/>
                    <Button Content="Update node" Command="{Binding RepointNodeCommand}" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding RepointResult}" TextWrapping="Wrap" FontSize="12.5"
                               IsVisible="{Binding RepointResult, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               Foreground="{Binding RepointOk, Converter={x:Static conv:BoolToBrushConverter.OkWarn}}"/>
                </StackPanel>

                <Separator IsVisible="{Binding VaultExists}"/>

                <!-- Change master password -->
                <StackPanel Spacing="6">
                    <TextBlock Text="CHANGE MASTER PASSWORD" Classes="eyebrow"/>
                    <TextBlock TextWrapping="Wrap" Classes="muted"
                               Text="Re-encrypts the real wallet under a new password. Your seed does not change. The duress password (if set) is unaffected and cannot be used here."/>
                    <TextBox Watermark="Current password" PasswordChar="&#9679;" Text="{Binding CurrentPassword}"/>
                    <TextBox Watermark="New password" PasswordChar="&#9679;" Text="{Binding NewPassword}"/>
                    <TextBox Watermark="Confirm new password" PasswordChar="&#9679;" Text="{Binding NewPasswordConfirm}"/>
                    <Button Content="Change password" Command="{Binding ChangePasswordCommand}" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding ChangePasswordResult}" TextWrapping="Wrap" FontSize="12.5"
                               IsVisible="{Binding ChangePasswordResult, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               Foreground="{Binding ChangePasswordOk, Converter={x:Static conv:BoolToBrushConverter.OkWarn}}"/>
                </StackPanel>

                <Separator/>

                <!-- About -->
                <StackPanel Spacing="6">
                    <TextBlock Text="ABOUT" Classes="eyebrow"/>
                    <TextBlock Text="XaultWallet" FontWeight="SemiBold"/>
                    <TextBlock Text="Brought to life in harmony." Classes="muted"/>
                    <Button Classes="link" Content="https://dboudreau.dev" Click="OpenLink_Click"
                            HorizontalAlignment="Left"/>
                </StackPanel>

                <Separator/>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="Save" Classes="accent" Command="{Binding SaveCommand}"/>
                    <TextBlock Text="{Binding SavedMessage}" VerticalAlignment="Center" Foreground="{StaticResource SuccessBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
