<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:XaultWallet.Desktop.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="620"
             x:Class="XaultWallet.Desktop.Views.StartupView"
             x:DataType="vm:StartupViewModel">

    <!-- Opacity-only animations: the one primitive Avalonia is guaranteed to interpolate.
         Staggered via Delay so the entrance still feels sequenced. -->
    <UserControl.Styles>
        <Style Selector="Ellipse.glowPulse">
            <Style.Animations>
                <Animation Duration="0:0:2.8" IterationCount="INFINITE" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.42"/></KeyFrame>
                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.12"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.42"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Border.fadeSeq">
            <Setter Property="Opacity" Value="0"/>
            <Style.Animations>
                <Animation Duration="0:0:0.5" FillMode="Forward" Easing="CubicEaseOut">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Ellipse.fadeDot">
            <Setter Property="Opacity" Value="0"/>
            <Style.Animations>
                <Animation Duration="0:0:0.4" Delay="0:0:0.35" FillMode="Forward" Easing="CubicEaseOut">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="StackPanel.fadeA">
            <Setter Property="Opacity" Value="0"/>
            <Style.Animations>
                <Animation Duration="0:0:0.5" Delay="0:0:0.3" FillMode="Forward" Easing="CubicEaseOut">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="StackPanel.fadeB">
            <Setter Property="Opacity" Value="0"/>
            <Style.Animations>
                <Animation Duration="0:0:0.5" Delay="0:0:0.55" FillMode="Forward" Easing="CubicEaseOut">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <Grid>
        <StackPanel Width="380" Spacing="28" VerticalAlignment="Center" HorizontalAlignment="Center">

            <!-- X badge with an ambient glow (glow pulses; the mark fades in) -->
            <Grid Width="150" Height="150" HorizontalAlignment="Center">
                <Ellipse Classes="glowPulse" Width="140" Height="140" HorizontalAlignment="Center" VerticalAlignment="Center"
                         Fill="{StaticResource AccentBrush}"/>

                <Border Classes="fadeSeq" Width="86" Height="86" CornerRadius="24"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="{StaticResource Surface}" BorderBrush="{StaticResource BorderStrong}"
                        BorderThickness="1" BoxShadow="0 16 44 -8 #77000000">
                    <Grid>
                        <Canvas Width="86" Height="86">
                            <Line StartPoint="27,25" EndPoint="59,61" Stroke="{StaticResource AccentBrush}"
                                  StrokeThickness="8.5" StrokeLineCap="Round"/>
                            <Line StartPoint="59,25" EndPoint="27,61" Stroke="{StaticResource TextPrimary}"
                                  StrokeThickness="8.5" StrokeLineCap="Round"/>
                        </Canvas>
                        <Ellipse Classes="fadeDot" Width="11" Height="11" HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Fill="{StaticResource Surface}" Stroke="{StaticResource AccentBrush}" StrokeThickness="2.5"/>
                    </Grid>
                </Border>
            </Grid>

            <StackPanel Classes="fadeA" Spacing="5">
                <TextBlock HorizontalAlignment="Center">
                    <Run Text="Xault" FontSize="24" FontWeight="Bold"/><Run Text="Wallet" FontSize="24" FontWeight="Light" Foreground="{StaticResource TextSecondary}"/>
                </TextBlock>
                <TextBlock Text="{Binding Status}" Classes="muted" HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel Classes="fadeB" Spacing="14">
                <ProgressBar IsIndeterminate="True" IsVisible="{Binding Checking}" Height="3" Width="220"
                             HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Detail}" Classes="eyebrow" HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center" MaxWidth="320"/>
                <Button Content="Continue anyway" Command="{Binding ContinueCommand}"
                        IsVisible="{Binding Checking}" HorizontalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
