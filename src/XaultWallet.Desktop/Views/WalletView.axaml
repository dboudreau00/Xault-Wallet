<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:XaultWallet.Desktop.ViewModels"
             xmlns:conv="clr-namespace:XaultWallet.Desktop"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="860" d:DesignHeight="640"
             x:Class="XaultWallet.Desktop.Views.WalletView"
             x:DataType="vm:WalletViewModel">

    <UserControl.Styles>
        <Style Selector="Border.fadeUp">
            <Setter Property="Opacity" Value="0"/>
            <Style.Animations>
                <Animation Duration="0:0:0.45" FillMode="Forward" Easing="CubicEaseOut">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <Grid Margin="24" RowDefinitions="Auto,Auto,*">

        <!-- ============ Balance + node sync ============ -->
        <Border Grid.Row="0" Classes="card fadeUp" Padding="24">
            <StackPanel Spacing="20">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="3">
                        <TextBlock Text="TOTAL BALANCE" Classes="eyebrow"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Classes="mono" FontSize="36" FontWeight="Bold"
                                       Text="{Binding Balance, StringFormat='{}{0:0.############}'}"/>
                            <TextBlock Text="XMR" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Bottom"
                                       Margin="0,0,0,8" Foreground="{StaticResource TextTertiary}"/>
                        </StackPanel>
                        <TextBlock Classes="muted"
                                   Text="{Binding UnlockedBalance, StringFormat='Spendable now: {0:0.############} XMR'}"/>
                        <Border IsVisible="{Binding HasLocked}" Background="{StaticResource InsetBg}"
                                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="6"
                                Padding="8,3" HorizontalAlignment="Left" Margin="0,2,0,0">
                            <TextBlock Classes="mono" FontSize="11" Foreground="{StaticResource WarningBrush}"
                                       Text="{Binding LockedBalance, StringFormat='⧗ {0:0.############} XMR maturing'}"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
                        <Button Content="Refresh" Command="{Binding RefreshCommand}" IsEnabled="{Binding IsReady}"/>
                        <Button Content="Lock" Classes="accent" Command="{Binding LockCommand}"/>
                    </StackPanel>
                </Grid>

                <Separator/>

                <!-- Node sync tracker (the signature readout) -->
                <StackPanel Spacing="9">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Ellipse Grid.Column="0" Width="9" Height="9" Margin="0,0,9,0" VerticalAlignment="Center"
                                 Fill="{Binding IsSynced, Converter={x:Static conv:BoolToBrushConverter.OkWarn}}"/>
                        <TextBlock Grid.Column="1" Classes="mono" FontSize="12.5" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondary}" Text="{Binding SyncText}"/>
                        <TextBlock Grid.Column="2" Classes="eyebrow" VerticalAlignment="Center" Text="NODE SYNC"/>
                    </Grid>
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding SyncProgress}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ============ Startup failure banner ============ -->
        <Border Grid.Row="1" IsVisible="{Binding StartupFailed}" Margin="0,14,0,0"
                Background="#2A1414" BorderBrush="#7A2E2E" BorderThickness="1" CornerRadius="12" Padding="16">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" TextWrapping="Wrap" VerticalAlignment="Center" Foreground="#F0B4B4"
                           Text="The wallet backend didn't start. Check that monero-wallet-rpc is set in Settings and your node is reachable, then retry."/>
                <Button Grid.Column="1" Content="Retry" Command="{Binding RetryStartupCommand}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ============ Tabs ============ -->
        <TabControl Grid.Row="2" Margin="0,16,0,0" IsEnabled="{Binding IsReady}">

            <TabItem Header="Receive">
                <StackPanel Spacing="12" Margin="2,16,2,2">
                    <TextBlock Text="YOUR ADDRESS" Classes="eyebrow"/>
                    <Border Background="{StaticResource InsetBg}" BorderBrush="{StaticResource BorderSubtle}"
                            BorderThickness="1" CornerRadius="10" Padding="14,12">
                        <TextBox Classes="mono" Text="{Binding PrimaryAddress}" IsReadOnly="True"
                                 TextWrapping="Wrap" BorderThickness="0" Background="Transparent"
                                 Padding="0" MinHeight="0" FontSize="12.5"
                                 Watermark="Your address appears once the wallet is open"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Copy address" Click="CopyAddress_Click"/>
                        <Button Content="New subaddress" Command="{Binding NewAddressCommand}"/>
                    </StackPanel>
                    <TextBlock Classes="muted" TextWrapping="Wrap"
                               Text="Share this address to receive XMR. A new subaddress gives you a fresh, unlinkable address for the same wallet."/>
                </StackPanel>
            </TabItem>

            <TabItem Header="Send">
                <ScrollViewer>
                    <StackPanel Spacing="14" Margin="2,16,2,2" MaxWidth="620" HorizontalAlignment="Left">
                        <StackPanel Spacing="6">
                            <TextBlock Text="DESTINATION ADDRESS" Classes="eyebrow"/>
                            <TextBox Classes="mono" Watermark="Recipient's Monero address" Text="{Binding SendAddress}"/>
                        </StackPanel>
                        <Grid ColumnDefinitions="*,12,Auto">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="AMOUNT (XMR)" Classes="eyebrow"/>
                                <TextBox Classes="mono" Watermark="0.00" Text="{Binding SendAmount}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="PRIORITY" Classes="eyebrow"/>
                                <ComboBox SelectedIndex="{Binding SendPriority}" MinWidth="150">
                                    <ComboBoxItem>Default</ComboBoxItem>
                                    <ComboBoxItem>Low</ComboBoxItem>
                                    <ComboBoxItem>Medium</ComboBoxItem>
                                    <ComboBoxItem>High</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                        <Button Content="Review &amp; send" Classes="accent" HorizontalAlignment="Left"
                                Command="{Binding ReviewSendCommand}" IsEnabled="{Binding !Sending}"/>
                        <ProgressBar IsIndeterminate="True" IsVisible="{Binding Sending}" Height="3"/>
                        <TextBlock Text="{Binding SendResult}" Classes="mono" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondary}"
                                   IsVisible="{Binding SendResult, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                        <!-- Payment proof from the last send -->
                        <Border IsVisible="{Binding HasLastTx}" Background="{StaticResource InsetBg}"
                                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="10" Padding="14">
                            <StackPanel Spacing="8">
                                <TextBlock Text="PAYMENT PROOF (LAST SEND)" Classes="eyebrow"/>
                                <TextBlock Classes="muted" TextWrapping="Wrap"
                                           Text="Share the transaction ID and transaction key to prove this payment on a block explorer. The tx key is safe to share — it does NOT let anyone spend your funds. Never share your seed or spend key."/>
                                <TextBlock Text="Transaction ID" Classes="eyebrow"/>
                                <TextBox Classes="mono" FontSize="12" Text="{Binding LastTxId}" IsReadOnly="True" TextWrapping="Wrap"/>
                                <TextBlock Text="Transaction key" Classes="eyebrow"/>
                                <TextBox Classes="mono" FontSize="12" Text="{Binding LastTxKey}" IsReadOnly="True" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Copy tx ID" Click="CopyLastTxId_Click"/>
                                    <Button Content="Copy tx key" Click="CopyLastTxKey_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Separator/>

                        <!-- Verify any payment -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="VERIFY A PAYMENT" Classes="eyebrow"/>
                            <TextBlock Classes="muted" TextWrapping="Wrap"
                                       Text="Confirm a payment reached an address using its transaction ID, transaction key, and the destination address."/>
                            <TextBox Classes="mono" FontSize="12" Watermark="Transaction ID" Text="{Binding VerifyTxId}"/>
                            <TextBox Classes="mono" FontSize="12" Watermark="Transaction key" Text="{Binding VerifyTxKey}"/>
                            <TextBox Classes="mono" FontSize="12" Watermark="Destination address" Text="{Binding VerifyAddress}"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Verify" Command="{Binding VerifyPaymentCommand}"/>
                                <Button Content="Use last send" Command="{Binding PrefillVerifyFromLastCommand}"
                                        IsVisible="{Binding HasLastTx}"/>
                                <Button Content="Fetch key from wallet" Command="{Binding FetchTxKeyCommand}"
                                        ToolTip.Tip="Look up the tx key for a transaction this wallet sent"/>
                            </StackPanel>
                            <TextBlock Text="{Binding VerifyResult}" TextWrapping="Wrap" FontSize="12.5"
                                       IsVisible="{Binding VerifyResult, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Foreground="{Binding VerifyOk, Converter={x:Static conv:BoolToBrushConverter.OkWarn}}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="History">
                <DataGrid ItemsSource="{Binding History}" IsReadOnly="True" Margin="0,14,0,0"
                          x:CompileBindings="False"
                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                          RowHeight="38">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="140"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80"/>
                        <DataGridTextColumn Header="Amount (XMR)"
                            Binding="{Binding Amount, Converter={x:Static conv:AtomicToXmrConverter.Instance}}" Width="150"/>
                        <DataGridTextColumn Header="Height" Binding="{Binding Height}" Width="100"/>
                        <DataGridTextColumn Header="Transaction" Binding="{Binding TxId}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <!-- ===== Send confirmation overlay (Monero is irreversible; always confirm) ===== -->
        <Border Grid.Row="0" Grid.RowSpan="3" IsVisible="{Binding ShowSendConfirm}" Background="#CC0D0D10">
            <Border Classes="card" Width="480" Padding="26" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Spacing="14">
                    <TextBlock Text="Confirm this send" Classes="h1"/>
                    <TextBlock Text="{Binding SendSummary}" Classes="muted"/>
                    <Border Background="{StaticResource InsetBg}" BorderBrush="{StaticResource BorderSubtle}"
                            BorderThickness="1" CornerRadius="10" Padding="12">
                        <TextBlock Classes="mono" FontSize="12" Text="{Binding SendAddress}" TextWrapping="Wrap"/>
                    </Border>
                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#E0A030"
                               Text="Monero transactions are irreversible. Double-check the address — funds sent to a wrong address cannot be recovered. The network fee is determined at submission."/>
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                        <Button Content="Cancel" Command="{Binding CancelSendCommand}"/>
                        <Button Content="Send now" Classes="accent" Command="{Binding ConfirmSendCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
